(load "Test.carp")

(load "main.carp")

(use-all Maybe Test URI Result)

(def uri "scheme://usr:pass@domain.tld:123/path?query=1#fragment")

(defn test-parsing []
  (do
    (IO.println "## Parsing")
    (with-test test
      (assert-equal test
        &(Just @"scheme")
        (scheme &(unsafe-from-success (URI.parse uri)))
        "we can parse and get the scheme correctly")
      (assert-equal test
        &(Just @"usr")
        (user &(unsafe-from-success (URI.parse uri)))
        "we can parse and get the user correctly")
      (assert-equal test
        &(Just @"pass")
        (password &(unsafe-from-success (URI.parse uri)))
        "we can parse and get the password correctly")
      (assert-equal test
        &(Just @"domain.tld")
        (host &(unsafe-from-success (URI.parse uri)))
        "we can parse and get the password correctly")
      (assert-equal test
        &(Just 123)
        (port &(unsafe-from-success (URI.parse uri)))
        "we can parse and get the port correctly")
      (assert-equal test
        &(Just @"path")
        (path &(unsafe-from-success (URI.parse uri)))
        "we can parse and get the path correctly")
      (assert-equal test
        &(Just @"query=1")
        (query &(unsafe-from-success (URI.parse uri)))
        "we can parse and get the query correctly")
      (assert-equal test
        &{@"query" @"1"}
        &(unsafe-from-success (query-map &(unsafe-from-success (URI.parse uri))))
        "we can parse and get the query correctly as a map")
      (assert-equal test
        &{@"key-one" @"val-one"
          @"key2" @"val2"}
        &(unsafe-from-success (query-map-from-str "key-one=val-one&key2=val2"))
        "we can parse and get the query correctly as a map from a string")
      (assert-equal test
        &{@"key one" @"val one"
          @"key2" @"val2"}
        &(unsafe-from-success
          (query-map-from-str "key%20one=val%20one&key2=val2"))
        "query-map-from-str percent-decodes keys and values")
      (assert-equal test
        &{@"data" @"abc=def"}
        &(unsafe-from-success (query-map-from-str "data=abc=def"))
        "query-map-from-str handles = in values")
      (assert-equal test
        &{@"token" @"eyJ=="}
        &(unsafe-from-success (query-map-from-str "token=eyJ=="))
        "query-map-from-str handles trailing = in values (base64)")
      (assert-equal test
        &{@"a" @"1"
          @"b" @"x=y"
          @"c" @"3"}
        &(unsafe-from-success (query-map-from-str "a=1&b=x=y&c=3"))
        "query-map-from-str handles = in values mixed with normal params")
      (assert-equal test
        &{@"key" @""}
        &(unsafe-from-success (query-map-from-str "key="))
        "query-map-from-str handles empty values")
      (assert-equal test
        &(Just @"fragment")
        (fragment &(unsafe-from-success (URI.parse uri)))
        "we can parse and get the fragment correctly")
      (assert-equal test
        &(Just @"")
        (path &(unsafe-from-success (URI.parse "/")))
        "we can parse relative URIs")
      ; an authority directly followed by ?query or #fragment (no path between)
      ; used to route the query/fragment text into the path, dropping it
      (assert-equal test
        &(Just @"q=1")
        (query &(unsafe-from-success (URI.parse "http://foo.com?q=1")))
        "a query directly after the host is captured, not swallowed as the path")
      (assert-true test
        (nothing? (path &(unsafe-from-success (URI.parse "http://foo.com?q=1"))))
        "no path is set when the authority is directly followed by a query")
      (assert-equal test
        &(Just @"frag")
        (fragment &(unsafe-from-success (URI.parse "http://foo.com#frag")))
        "a fragment directly after the host is captured, not swallowed as the path")
      (assert-equal test
        &(Just @"q=1")
        (query &(unsafe-from-success (URI.parse "http://foo.com:8080?q=1")))
        "a query directly after host:port is captured, not swallowed as the path")
      (assert-equal test
        &(Just 8080)
        (port &(unsafe-from-success (URI.parse "http://foo.com:8080?q=1")))
        "the port still parses when it is directly followed by a query")
      (assert-equal test
        &(Just @"frag")
        (fragment &(unsafe-from-success (URI.parse "http://foo.com:8080#frag")))
        "a fragment directly after host:port is captured, not swallowed as the path"))))

(defn test-escaping []
  (do
    (IO.println "## Escaping")
    (with-test test
      (assert-equal test "abcd%20efg" &(escape "abcd efg") "we can escape URIs")
      (assert-equal test
        "abcd efg"
        &(unescape "abcd%20efg")
        "we can unescape URIs")
      (assert-equal test
        "test%"
        &(unescape "test%")
        "unescape passes through truncated percent at end")
      (assert-equal test
        "test%2"
        &(unescape "test%2")
        "unescape passes through percent with only one hex digit at end")
      (assert-equal test
        &(Error @"Invalid URI: bad port at character 20")
        &(URI.parse "https://domain.tld:1ab3/")
        "invalid ports lead to errors")
      (assert-equal test
        10
        (String.length &(escape "abcd efg"))
        "escape output length matches visible content (no trailing NULs)")
      (assert-equal test
        8
        (String.length &(unescape "abcd%20efg"))
        "unescape output length matches visible content (no trailing NULs)"))))

(defn test-query-string-from-map []
  (do
    (IO.println "## Query String From Map")
    (with-test test
      (assert-equal test
        ""
        &(query-string-from-map &{})
        "empty map produces empty string")
      (assert-equal test
        "key=val"
        &(query-string-from-map &{@"key" @"val"})
        "single pair produces key=val")
      (assert-equal test
        "key%20one=val%20one"
        &(query-string-from-map &{@"key one" @"val one"})
        "query-string-from-map percent-encodes keys and values"))))

(defn test-stringification []
  (do
    (IO.println "## Stringification")
    (with-test test
      (let [s &(str &(unsafe-from-success (URI.parse uri)))]
        (assert-equal test
          uri
          s
          "we can convert our representation to a string again correctly")))))

(def base-uri "http://a/b/c/d;p?q")

(defn resolved-str [ref-str]
  (let [base (unsafe-from-success (URI.parse base-uri))]
    (str &(unsafe-from-success (URI.resolve &base ref-str)))))

(defn test-resolve []
  (do
    (IO.println "## Resolve (RFC 3986 Section 5.4)")
    (with-test test
      (assert-equal test "http://a/b/c/g" &(resolved-str "g") "resolve g")
      (assert-equal test "http://a/b/c/g" &(resolved-str "./g") "resolve ./g")
      (assert-equal test "http://a/b/c/g/" &(resolved-str "g/") "resolve g/")
      (assert-equal test "http://a/g" &(resolved-str "/g") "resolve /g")
      (assert-equal test "http://g/p" &(resolved-str "//g/p") "resolve //g/p")
      (assert-equal test "http://a/b/c/d;p?y" &(resolved-str "?y") "resolve ?y")
      (assert-equal test "http://a/b/c/g?y" &(resolved-str "g?y") "resolve g?y")
      (assert-equal test
        "http://a/b/c/d;p?q#s"
        &(resolved-str "#s")
        "resolve #s")
      (assert-equal test "http://a/b/c/g#s" &(resolved-str "g#s") "resolve g#s")
      (assert-equal test
        "http://a/b/c/g?y#s"
        &(resolved-str "g?y#s")
        "resolve g?y#s")
      (assert-equal test "http://a/b/c/;x" &(resolved-str ";x") "resolve ;x")
      (assert-equal test "http://a/b/c/g;x" &(resolved-str "g;x") "resolve g;x")
      (assert-equal test
        "http://a/b/c/g;x?y#s"
        &(resolved-str "g;x?y#s")
        "resolve g;x?y#s")
      (assert-equal test "http://a/b/c/d;p?q" &(resolved-str "") "resolve empty")
      (assert-equal test "http://a/b/c/" &(resolved-str ".") "resolve .")
      (assert-equal test "http://a/b/c/" &(resolved-str "./") "resolve ./")
      (assert-equal test "http://a/b/" &(resolved-str "..") "resolve ..")
      (assert-equal test "http://a/b/" &(resolved-str "../") "resolve ../")
      (assert-equal test "http://a/b/g" &(resolved-str "../g") "resolve ../g")
      (assert-equal test "http://a/" &(resolved-str "../..") "resolve ../..")
      (assert-equal test "http://a/" &(resolved-str "../../") "resolve ../../")
      (assert-equal test
        "http://a/g"
        &(resolved-str "../../g")
        "resolve ../../g")
      (assert-equal test
        "http://a/g"
        &(resolved-str "../../../g")
        "resolve ../../../g")
      (assert-equal test
        "http://a/g"
        &(resolved-str "../../../../g")
        "resolve ../../../../g")
      (assert-equal test
        "http://a/b/c/g."
        &(resolved-str "g.")
        "resolve g. (dot is part of segment)")
      (assert-equal test
        "http://a/b/c/.g"
        &(resolved-str ".g")
        "resolve .g (dot is part of segment)")
      (assert-equal test
        "http://a/b/c/g.."
        &(resolved-str "g..")
        "resolve g.. (dots are part of segment)")
      (assert-equal test
        "http://a/b/c/..g"
        &(resolved-str "..g")
        "resolve ..g (dots are part of segment)")
      (assert-equal test
        "http://a/b/c/g?y/./x"
        &(resolved-str "g?y/./x")
        "resolve g?y/./x (dots in query are literal)")
      (assert-equal test
        "http://a/b/c/g?y/../x"
        &(resolved-str "g?y/../x")
        "resolve g?y/../x (dots in query are literal)")
      (assert-equal test
        "http://a/b/c/g#s/./x"
        &(resolved-str "g#s/./x")
        "resolve g#s/./x (dots in fragment are literal)")
      (assert-equal test
        "http://a/b/c/g#s/../x"
        &(resolved-str "g#s/../x")
        "resolve g#s/../x (dots in fragment are literal)"))))

(defn test-opaque []
  (do
    (IO.println "## Opaque URIs")
    (with-test test
      (assert-equal test
        &(Just @"mailto")
        (scheme &(unsafe-from-success (URI.parse "mailto:veit@veitheller.de")))
        "we parse the scheme of an opaque URI")
      (assert-equal test
        &(Just @"veit@veitheller.de")
        (opaque &(unsafe-from-success (URI.parse "mailto:veit@veitheller.de")))
        "we parse the opaque part as everything after the colon")
      (assert-equal test
        &(Just @"g")
        (opaque &(unsafe-from-success (URI.parse "http:g")))
        "single-character opaque parts are preserved")
      ; round-tripping opaque URIs used to double-free in `str` and emit a
      ; spurious trailing slash; these guard against regressions.
      (assert-equal test
        "mailto:veit@veitheller.de"
        &(str &(unsafe-from-success (URI.parse "mailto:veit@veitheller.de")))
        "we stringify an opaque URI back to the original")
      (assert-equal test
        "urn:isbn:0451450523"
        &(str &(unsafe-from-success (URI.parse "urn:isbn:0451450523")))
        "we stringify an opaque URI with colons in the opaque part")
      (assert-equal test
        "http:g"
        &(str &(unsafe-from-success (URI.parse "http:g")))
        "we stringify an opaque URI without a spurious trailing slash"))))

(defn main []
  (Array.sum
    &[(test-parsing)
      (test-escaping)
      (test-query-string-from-map)
      (test-stringification)
      (test-resolve)
      (test-opaque)]))
